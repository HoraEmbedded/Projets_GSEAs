{
  "version": 1,
  "author": "PlatformIO STM32 Vending Machine Touch Screen",
  "editor": "wokwi",
  "parts": [
    { "type": "board-st-nucleo-c031c6", "id": "nucleo", "top": 200, "left": 50, "attrs": {} },
    { "type": "wokwi-ili9341-touch", "id": "touch_screen", "top": -220, "left": 0, "attrs": {} },
    { "type": "wokwi-pushbutton", "id": "btn_cancel", "top": 230, "left": 450, "attrs": { "color": "red", "label": "Annuler" } },
    { "type": "wokwi-led", "id": "led_prod", "top": 120, "left": -120, "attrs": { "color": "green", "label": "Moteur" } },
    { "type": "wokwi-led", "id": "led_pay", "top": 200, "left": -120, "attrs": { "color": "yellow", "label": "Paiement" } },
    { "type": "wokwi-led", "id": "led_err", "top": 280, "left": -120, "attrs": { "color": "red", "label": "Erreur" } }
  ],
  "connections": [
    [ "$serialMonitor:TX", "nucleo:PA3", "", [] ],
    [ "$serialMonitor:RX", "nucleo:PA2", "", [] ],

    [ "nucleo:GND.1", "touch_screen:GND", "black", [ "v0" ] ],
    [ "nucleo:5V.1", "touch_screen:VCC", "red", [ "v0" ] ],
    [ "nucleo:3V3.1", "touch_screen:LED", "red", [ "v0" ] ],
    
    [ "nucleo:PA5", "touch_screen:CLK", "blue", [ "v0" ] ],
    [ "nucleo:PA6", "touch_screen:MISO", "green", [ "v0" ] ],
