    [ "nucleo:PB0", "touch_screen:CS", "yellow", [ "v0" ] ],
    [ "nucleo:PB1", "touch_screen:D/C", "purple", [ "v0" ] ],
    [ "nucleo:PB2", "touch_screen:RESET", "white", [ "v0" ] ],

    [ "nucleo:PB10", "touch_screen:T_CS", "cyan", [ "v0" ] ],
    [ "nucleo:PB11", "touch_screen:T_IRQ", "brown", [ "v0" ] ],

    [ "nucleo:PC6", "btn_cancel:1.l", "red", [ "v0" ] ],
    [ "nucleo:GND.2", "btn_cancel:2.r", "black", [ "v0" ] ],

    [ "nucleo:PB4", "led_prod:A", "green", [ "v0" ] ],
    [ "nucleo:GND.3", "led_prod:C", "black", [ "v0" ] ],
    
    [ "nucleo:PB5", "led_pay:A", "yellow", [ "v0" ] ],
    [ "nucleo:GND.3", "led_pay:C", "black", [ "v0" ] ],

    [ "nucleo:PB6", "led_err:A", "red", [ "v0" ] ],
    [ "nucleo:GND.3", "led_err:C", "black", [ "v0" ] ]
